{
  "name": "career-brand",
  "version": "0.1.0",
  "private": true,
  "description": "Single source of truth for resume, portfolio, LinkedIn, and GitHub profile",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs --full",
    "build:public": "node scripts/build.mjs --public",
    "build:full": "node scripts/build.mjs --full",
    "validate": "node scripts/validate.mjs",
    "preview": "npm run build:public && node scripts/preview.mjs",
    "preview:serve": "node scripts/preview.mjs",
    "preview:lan": "npm run build:public && node scripts/preview.mjs --lan"
  }
}
